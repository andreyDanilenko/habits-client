# Пусто = запросы на /api/v1 с текущего origin (Vite проксирует на бэкенд).
# Так HttpOnly access_token оказывается на localhost:3000 и Socket.IO к nest-satellite получает куку.
VITE_API_URL=

# Куда Vite проксирует /api (только для dev-сервера)
# DEV_API_PROXY_TARGET=http://localhost:8080

# Опционально: отдельный URL для realtime (если не проксируете socket.io)
# VITE_REALTIME_URL=
